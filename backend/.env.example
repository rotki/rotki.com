# Server
# PORT=4000
# STATIC_DIR=./dist
# BASE_URL=https://rotki.com

# OAuth
# GOOGLE_CLIENT_SECRET=
# MONERIUM_CLIENT_SECRET=
# MONERIUM_AUTH_BASE_URL=https://api.monerium.dev

# Redis (optional — falls back to memory cache)
# REDIS_HOST=localhost:6379
# REDIS_PASSWORD=

# Image cache
# IMAGE_CACHE_DIR=./image-cache

# Logging (debug, info, warn, error)
# LOG_LEVEL=info

# Feature flags
# SPONSORSHIP_ENABLED=false

# Dev mode (uncomment for local development)
# DEV_MODE=true
# NUXT_DEV_URL=http://localhost:3001
# PROXY_DOMAIN=rotki.com
# PROXY_INSECURE=true
