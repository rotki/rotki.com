+// Prefix public-asset virtual ids with a null byte so they are treated as
+// proper Rollup/Vite virtual modules. Without it, Vite 7.3.2+ strips the query
+// to `virtual:public`, which is not a real filesystem path, and the server.fs
+// access check denies the transform ("Denied ID virtual:public?...") before the
+// load hook runs - breaking /public asset (svg/img) imports under the nuxt
+// vitest environment. Backport of the upstream fix; drop this patch once it
+// ships in a released nuxt (> 4.4.6).
+const PREFIX = "\0virtual:public?";
+const PREFIX_RE = /^\0virtual:public\?/;
