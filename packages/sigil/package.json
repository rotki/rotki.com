{
  "name": "@rotki/sigil",
  "version": "2026.4.3",
  "description": "Shared analytics catalog and helpers for rotki.com Umami (Sigil) tracking",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "0.21.7",
    "typescript": "catalog:",
    "vitest": "4.1.2"
  }
}
