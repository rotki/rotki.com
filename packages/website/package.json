    "msw": "catalog:",
    "nuxt": "catalog:",
    "postcss": "catalog:",
    "postcss-html": "catalog:",
    "postcss-import": "catalog:",
    "rollup": "catalog:",
    "satori": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
