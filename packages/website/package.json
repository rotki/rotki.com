{
  "name": "@rotki/website",
  "version": "2026.6.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev --host 0.0.0.0 --port 3001",
    "build": "nuxi typecheck && nuxi build",
    "clean": "rimraf node_modules .output .nuxt dist",
    "start": "nuxi start",
    "preview": "nuxi preview",
    "generate": "nuxi generate",
    "postinstall": "nuxi prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint **/*.{vue,css} --ignore-path .gitignore",
    "lint:all": "pnpm lint && pnpm lint:style",
    "typecheck": "npx nuxi typecheck",
    "test": "vitest run",
    "test:watch": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "coverage": "vitest run --coverage",
    "og:mint": "node scripts/generate-og-mint.ts",
    "seo:audit": "node scripts/seo-audit.ts",
    "gen:integration-stubs": "npx tsx scripts/generate-integration-stubs.ts",
    "integrations:changed": "npx tsx scripts/integrations-changed.ts"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "catalog:",
    "@nuxtjs/robots": "catalog:",
    "@nuxtjs/tailwindcss": "catalog:",
    "@pinia/nuxt": "catalog:",
    "@rotki/sigil": "workspace:*",
    "@vuelidate/core": "catalog:",
    "@vuelidate/validators": "catalog:",
    "@vueuse/core": "catalog:",
    "@vueuse/math": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "@vueuse/shared": "catalog:",
    "@wagmi/connectors": "catalog:",
    "@wagmi/core": "catalog:",
    "@walletconnect/universal-provider": "catalog:",
    "better-sqlite3": "catalog:",
    "braintree-web": "catalog:",
    "nuxt-llms": "catalog:",
    "pinia": "catalog:",
    "plainfp": "catalog:",
    "qrcode": "catalog:",
    "swiper": "catalog:",
    "viem": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nuxt/content": "catalog:",
    "@nuxt/devtools": "catalog:",
    "@nuxt/fonts": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "@nuxtjs/sitemap": "catalog:",
    "@playwright/test": "catalog:",
    "@resvg/resvg-js": "catalog:",
    "@rotki/ui-library": "catalog:",
    "@types/braintree-web": "catalog:",
